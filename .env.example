# Modelo de variáveis de ambiente. Copie para `.env` e preencha com os valores reais.
#   cp .env.example .env
# O `.env` NUNCA é versionado (contém credenciais). Peça os valores ao time.

# --- Banco MySQL (macro_brasil) ---
# Servidor na rede local da empresa (ex.: 192.168.15.200)
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=

# --- API FRED (Federal Reserve) ---
# Gere uma chave em https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
